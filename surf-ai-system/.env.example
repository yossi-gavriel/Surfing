AWS_REGION=us-east-1
S3_BUCKET=surf-ai-raw-videos
SQLITE_DB_PATH=/app/data/surf_ai.db
APP_VERSION=dev
DEPLOYMENT_VERSION=dev
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-ingestion
CHUNK_DURATION=10
INPUT_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-ingestion
OUTPUT_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-tracks
FRAME_PROCESSOR_DLQ_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-frame-dlq
YOLO_MODEL=yolov8n.pt
EMBEDDING_INPUT_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-tracks
EMBEDDING_OUTPUT_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-embeddings
EMBEDDING_DLQ_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-embedding-dlq
INSIGHTFACE_MODEL=buffalo_s
MATCHING_INPUT_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-embeddings
MATCHING_OUTPUT_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-matches
MATCHING_DLQ_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-matching-dlq
CLIPPER_INPUT_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-clips
CLIPPER_DLQ_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/surf-ai-clipper-dlq
JWT_SECRET=replace-with-long-random-secret-at-least-32-chars
JWT_EXPIRE_HOURS=168
JWT_ISSUER=surf-ai-api
JWT_AUDIENCE=surf-ai-users
JWT_LEEWAY_SECONDS=30
ADMIN_EMAILS=admin@example.com
MIN_FACE_SIZE=40
MIN_CONFIDENCE=0.5
MIN_BLUR_SCORE=50.0
ALLOW_SINGLE_EMBEDDING_DEBUG=false
UPLOAD_RATE_LIMIT_MAX_REQUESTS=5
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=300
CAMERA_POLL_INTERVAL=10
INGESTION_METRICS_LOG_INTERVAL=25
FRAME_PROCESSOR_MAX_RECEIVE_COUNT=5
FRAME_PROCESSOR_METRICS_LOG_INTERVAL=25
EMBEDDING_MAX_RECEIVE_COUNT=5
EMBEDDING_METRICS_LOG_INTERVAL=25
MATCHING_MAX_RECEIVE_COUNT=5
MATCHING_METRICS_LOG_INTERVAL=25
CLIPPER_MAX_RECEIVE_COUNT=5
CLIPPER_METRICS_LOG_INTERVAL=25
INGESTION_LEASE_TTL_SECONDS=60
FRAME_PROCESSOR_LEASE_TTL_SECONDS=60
EMBEDDING_LEASE_TTL_SECONDS=60
MATCHING_LEASE_TTL_SECONDS=60
CLIPPER_LEASE_TTL_SECONDS=60
ANALYSIS_ENABLED=false
ANALYSIS_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/analysis-queue
ANALYSIS_INPUT_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/analysis-queue
ANALYSIS_DLQ_SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/analysis-dlq
ANALYSIS_MODEL_VERSION=wave_surfer_v1.0
ANALYSIS_YOLO_MODEL_PATH=/app/services/analysis-service/models/yolo_wave_surfer.pt
ANALYSIS_SAMPLE_FPS=10
ANALYSIS_DEBUG_ARTIFACTS=true
ANALYSIS_MAX_RECEIVE_COUNT=5
ANALYSIS_LEASE_TTL_SECONDS=60
ANALYSIS_METRICS_LOG_INTERVAL=10
